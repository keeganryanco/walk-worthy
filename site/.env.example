# Optional shared app secret for simple request auth.
TEND_APP_SHARED_SECRET=

# OpenAI (primary + escalation)
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-5-mini
OPENAI_ESCALATION_MODEL=gpt-5.1
OPENAI_TRANSLATION_MODEL=

# Gemini
GEMINI_API_KEY=
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_TRANSLATION_MODEL=

# Localization endpoint cache TTL (seconds, default 7 days).
LOCALIZATION_CACHE_TTL_SECONDS=604800

# PostHog server-side capture for AI usage/cost telemetry
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Optional cost estimation (USD per 1M tokens).
# If unset, usage events are still tracked but estimated_cost_usd will be 0/empty.
OPENAI_INPUT_COST_PER_1M_TOKENS=
OPENAI_OUTPUT_COST_PER_1M_TOKENS=
GEMINI_INPUT_COST_PER_1M_TOKENS=
GEMINI_OUTPUT_COST_PER_1M_TOKENS=

# Optional model-specific override format:
# <PROVIDER>_<MODEL>_<INPUT|OUTPUT>_COST_PER_1M_TOKENS
# Example:
# OPENAI_GPT_5_MINI_INPUT_COST_PER_1M_TOKENS=

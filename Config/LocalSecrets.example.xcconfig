// Copy this file to Config/LocalSecrets.xcconfig and fill in your local values.
// This file is intentionally safe to commit. Do not commit LocalSecrets.xcconfig.

// IMPORTANT: in .xcconfig files, writing https:// directly truncates after https:
// because // is treated as a comment. Use host only (scheme is added in code).
TENDAI_BASE_URL = walk-worthy-kohl.vercel.app
TENDAI_APP_KEY = your_shared_secret_here
POSTHOG_API_KEY = phc_your_project_key
POSTHOG_HOST = us.i.posthog.com
REVENUECAT_IOS_PUBLIC_SDK_KEY = appl_your_revenuecat_ios_key
REVENUECAT_ENTITLEMENT_ID = premium
